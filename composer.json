{
  "name": "joseluis21/integrafacturacion-sdk-php",
  "description": "SDK en PHP para consumir la API de IntegraFacturacion.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "integrafacturacion",
    "dte",
    "sii",
    "sdk",
    "php"
  ],
  "homepage": "https://github.com/JoseLuis21/integrafacturacion-sdk-php",
  "authors": [
    {
      "name": "Jose Luis",
      "homepage": "https://github.com/JoseLuis21"
    }
  ],
  "require": {
    "php": "^8.1",
    "ext-json": "*",
    "ext-curl": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "IntegraFacturacion\\": "src/"
    },
    "files": [
      "src/Domain/Dte/JsonHelpers.php",
      "src/Domain/Dte/Common.php",
      "src/Domain/Dte/Documents.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "IntegraFacturacion\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
